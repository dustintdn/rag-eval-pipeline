OPENAI_API_KEY=

CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=rag_docs

CHUNK_SIZE=512
CHUNK_OVERLAP=64

TOP_K=4

LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

PROMPT_VERSION=v1_cite_sources
ENABLE_SEMANTIC_CACHE=false

COHERE_API_KEY=
ENABLE_RERANKER=false
RERANKER_MODEL=rerank-english-v3.0
RERANKER_TOP_N=4
RERANKER_FETCH_K=10

ENABLE_HYBRID_RETRIEVAL=false
HYBRID_BM25_WEIGHT=0.4

# When set, mutating API endpoints require Authorization: Bearer <token>.
# Leave empty for open local dev.
API_TOKEN=

# Async eval jobs older than this many days and in a terminal state
# are pruned on API startup. Set to 0 to disable.
JOB_TTL_DAYS=30
JOB_PRUNE_INTERVAL_HOURS=24

# Per-IP rate limits in slowapi "N/minute" or "N/second" syntax.
RATE_LIMIT_QUERY=30/minute
RATE_LIMIT_EVAL_RUN=5/minute
RATE_LIMIT_INGEST=10/minute
